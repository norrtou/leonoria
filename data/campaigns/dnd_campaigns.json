{
  "_meta": {
    "file": "dnd_campaigns.json",
    "purpose": "Master list of official D&D campaigns used as structural and mechanical templates for Leonoria game creation",
    "schema_version": "1.0",
    "notes": [
      "Each campaign entry is a core template — fields marked null are placeholders to be filled with campaign-specific data.",
      "special_rules: Unique mechanical rules, subsystems, or house rules introduced in this campaign.",
      "themes: Narrative and tonal tags used when procedurally selecting campaign flavour.",
      "recommended_level_range: The intended character level span of the campaign.",
      "setting: The D&D world/plane the campaign primarily takes place in.",
      "tone: Overall atmosphere (e.g. horror, political intrigue, dungeon crawl, exploration).",
      "encounter_style: Dominant encounter type — combat-heavy, social, exploration, puzzle, mixed.",
      "key_factions: Major factions or organisations the players interact with.",
      "signature_locations: Iconic or named locations central to the campaign.",
      "boss_encounters: Major antagonist encounters and their mechanical notes.",
      "loot_and_rewards: Campaign-specific magic items, treasures, or reward structures.",
      "unique_mechanics: Custom subsystems (e.g. sanity, corruption, sailing, downtime variants).",
      "adaptability_notes: Notes on how easily the campaign adapts to Leonoria's world."
    ],
    "categories": [
      "modern_5e_core",
      "classic_modules",
      "4e_campaign_chain"
    ]
  },

