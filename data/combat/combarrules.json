      "Slashing",
      "Piercing",
      "Bludgeoning",
      "Fire",
      "Cold",
      "Lightning",
      "Thunder",
      "Acid",
      "Poison",
      "Necrotic",
      "Radiant",
      "Psychic",
      "Force"
