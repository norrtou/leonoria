    "critical": {
      "condition": "Natural 20",
      "effect": "Roll all damage dice twice"
    },
    "fumble": {
      "condition": "Natural 1",
      "effect": "Automatic miss"
    },
    "attack_types": [
      "Melee Weapon Attack",
      "Ranged Weapon Attack",
      "Melee Spell Attack",
      "Ranged Spell Attack"
    ]
  },

  "damage_system": {
    "damage_roll": "Defined by weapon/spell",
