{
  "meta": {
    "system": "D&D 5e Combat",
    "design_goal": "Deterministic, machine-readable combat rules",
    "time_unit": {
      "round": "6 seconds",
      "turn": "one creature's actions within a round"
    }
  },

  "core_flow": {
    "combat_start": [
      "Determine surprise",
      "Roll initiative for all participants",
      "Sort turn order descending",
      "Begin round loop"
    ],
    "round_loop": {
      "repeat_until": "combat_end_condition",
      "steps": [
        "Each creature takes a turn in initiative order",
        "After last creature, increment round counter"
      ]
    },
    "combat_end_condition": [
      "All enemies defeated",
      "All enemies flee",
      "Narrative resolution"
    ]
  },

  "initiative": {
    "roll": "1d20 + Dexterity modifier",
    "tie_breaker": [
      "Higher Dexterity score",
      "If still tied: random or DM choice"
    ],
    "properties": {
      "fixed_order": "Order remains constant unless modified",
      "can_delay": false
    }
  },

  "surprise": {
    "condition": "One side is unaware of the other",
    "effect": {
      "surprised_creature": [
        "Cannot move on first turn",
        "Cannot take actions on first turn",
        "Cannot take reactions until turn ends"
      ]
    }
  },

  "turn_structure": {
    "components": [
      "start_of_turn_effects",
      "movement",
      "action",
      "bonus_action",
      "free_interaction",
      "end_of_turn_effects"
    ]
  },

  "action_economy": {
    "action": {
      "limit": 1,
      "types": [
        "Attack",
        "Cast Spell",
        "Dash",
        "Disengage",
        "Dodge",
        "Help",
        "Hide",
        "Ready",
        "Search",
        "Use Object"
      ]
    },
    "bonus_action": {
      "limit": 1,
      "condition": "Only if granted by ability/spell"
    },
    "reaction": {
      "limit": 1,
      "reset": "Start of your turn",
      "trigger_based": true
    },
    "movement": {
      "split_allowed": true,
      "total_limit": "Speed stat (e.g. 30 ft)"
    },
    "free_interaction": {
      "limit": 1,
      "examples": [
        "Draw weapon",
        "Open door",
        "Pick up object"
      ]
    }
  },

  "attack_system": {
    "attack_roll": {
      "formula": "1d20 + attack_modifier",
