      "trigger": "Defined condition",
      "effect": "Use reaction to execute held action"
    }
  },

  "cover": {
    "half_cover": "+2 AC and Dex saves",
    "three_quarters_cover": "+5 AC and Dex saves",
    "full_cover": "Cannot be targeted directly"
  },

  "visibility_and_light": {
    "bright_light": "Normal vision",
    "dim_light": "Lightly obscured (disadvantage perception)",
    "darkness": "Heavily obscured (effectively blinded)"
